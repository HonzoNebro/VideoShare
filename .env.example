# Create a bot with BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=123456789:replace-me

# Comma-separated Telegram user ids allowed to use the bot.
# In private chats, this is usually enough.
ALLOWED_USER_IDS=123456789

# Comma-separated chat ids where anyone can use the bot by mentioning it:
# @your_bot_username https://example.com/video
# For groups/supergroups, add the negative chat id here.
ALLOWED_CHAT_IDS=

# Where temporary downloads are stored.
DOWNLOAD_DIR=/tmp/videoshare-bot

# Upload limit used by the bot. Values above 50 MB require a local Telegram Bot API server.
MAX_UPLOAD_MB=1024

# Local Telegram Bot API server, required for new uploads above Telegram cloud's 50 MB limit.
# Example local server defaults:
# TELEGRAM_API_BASE_URL=http://127.0.0.1:8081/bot
# TELEGRAM_API_BASE_FILE_URL=http://127.0.0.1:8081/file/bot
TELEGRAM_API_BASE_URL=
TELEGRAM_API_BASE_FILE_URL=
TELEGRAM_LOCAL_MODE=false

# HTTP timeouts for Telegram requests. Large local Bot API uploads need generous values.
TELEGRAM_CONNECT_TIMEOUT_SECONDS=30
TELEGRAM_READ_TIMEOUT_SECONDS=600
TELEGRAM_WRITE_TIMEOUT_SECONDS=600
TELEGRAM_POOL_TIMEOUT_SECONDS=30

# Optional safety knobs.
MAX_DESCRIPTION_CHARS=650
METADATA_TIMEOUT_SECONDS=60
DOWNLOAD_TIMEOUT_SECONDS=600
UPLOAD_TIMEOUT_SECONDS=300
QUIET_UNAUTHORIZED=false
LOG_LEVEL=INFO
HTTP_LOG_LEVEL=WARNING

# Optional private recipient for operational errors from Telegram/code/config.
# Expected video failures still answer in the original chat.
ERROR_REPORT_USER_ID=

# Telegram file_id cache. The bot stores no videos by default, only Telegram file ids.
CACHE_DB_PATH=
CACHE_TTL_DAYS=30

# Heavy processing queue. Use 1 on Raspberry Pi 4.
MAX_CONCURRENT_JOBS=1

# Minimum seconds between non-critical progress message edits.
PROGRESS_UPDATE_INTERVAL_SECONDS=10

# Preventive limits before downloading.
MAX_VIDEO_DURATION_SECONDS=1200
MAX_ESTIMATED_DOWNLOAD_MB=1024

# Legacy max video quality by height for older/default flows.
MAX_VIDEO_HEIGHT=480

# Caption policy. Values: full, link, none.
# Defaults keep full text in private chats and no caption in groups.
CAPTION_MODE_PRIVATE=full
CAPTION_MODE_GROUP=none

# Optional yt-dlp cookies file for sites that request sign-in or bot verification.
YTDLP_COOKIES_FILE=

# Optional YouTube JS challenge support.
YTDLP_JS_RUNTIMES=deno
YTDLP_REMOTE_COMPONENTS=ejs:npm
